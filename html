<!-- ====== よくあるご質問 ====== -->
<div id="page-faq" class="page">
  <div class="container section">
    <div class="breadcrumb">
      <a onclick="showPage('home')">Home</a><span>»</span> よくあるご質問
    </div>
    <h2 class="section-title">よくあるご質問</h2>

    <div class="faq-item">
      <div class="faq-q">
        <span class="faq-q-label">Q.</span>
        <span class="faq-q-text">●●●●●●●に対応していますか？</span>
      </div>
      <div class="faq-a">
        <span class="faq-a-label">A.</span>対応しています。<br>
        ●●●●●●は、●●●●に対応しています。詳しくはスタッフまでお問い合わせください。
